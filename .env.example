# SignalForge Configuration
# Copy this file to .env and adjust values

# Application
APP_NAME=SignalForge
APP_VERSION=2.0.0
DEBUG=false

# Database
DATABASE_URL=sqlite:///./signalforge.db

# JWT Authentication
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Encryption (exactly 32 chars for AES-256 Fernet key)
MASTER_ENCRYPTION_KEY=this-is-a-32-char-key-for-aes-256

# CORS (comma-separated or *)
CORS_ORIGINS=*

# Worker
WORKER_POLL_INTERVAL_SECONDS=2
STALE_EXECUTION_TIMEOUT_MINUTES=30
MAX_CONCURRENT_EXECUTIONS_PER_WORKSPACE=3

# Default LLM Provider URLs
DEFAULT_OPENAI_COMPATIBLE_URL=http://localhost:20128/v1
DEFAULT_OLLAMA_URL=http://localhost:11434
DEFAULT_TIMEOUT_SECONDS=120
